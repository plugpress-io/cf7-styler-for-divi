{
  "slug": "dvppl_cf7_styler",
  "name": "plugpress/cf7-styler",
  "d4Shortcode": "dvppl_cf7_styler",
  "title": "Contact form 7 Styler",
  "titles": "Contact form 7 Stylers",
  "category": "module",
  "description": "Style your Contact Form 7 forms with Divi.",
  "settings": {
    "general": {
      "toggles": {
        "general": {
          "title": "General",
          "settings": [
            "cf7",
            "use_form_header",
            "form_header_title",
            "form_header_text",
            "use_icon",
            "header_icon",
            "header_img"
          ]
        }
      }
    },
    "advanced": {
      "toggles": {
        "common": {
          "title": "Common",
          "settings": [
            "form_bg",
            "form_padding",
            "use_form_button_fullwidth",
            "button_alignment"
          ]
        },
        "form_header": {
          "title": "Form Header",
          "tabbedSubtoggles": true,
          "subToggles": {
            "common_tab": {
              "name": "Common",
              "settings": [
                "form_header_bg",
                "form_header_bottom",
                "form_header_img_bg",
                "form_header_icon_color"
              ]
            },
            "title_tab": {
              "name": "Title"
            },
            "text_tab": {
              "name": "Text"
            }
          }
        },
        "form_text": {
          "title": "Form Text",
          "tabbedSubtoggles": true,
          "subToggles": {
            "field_tab": {
              "name": "Field"
            },
            "label_tab": {
              "name": "Label",
              "settings": [
                "form_label_spacing"
              ]
            },
            "placeholder_tab": {
              "name": "Placeholder"
            }
          }
        },
        "form_field": {
          "title": "Fields",
          "settings": [
            "form_field_height",
            "form_field_padding",
            "form_background_color",
            "form_field_active_color",
            "form_field_spacing"
          ]
        },
        "radio_checkbox": {
          "title": "Radio & Checkbox",
          "settings": [
            "cr_custom_styles",
            "cr_size",
            "cr_background_color",
            "cr_selected_color",
            "cr_border_color",
            "cr_border_size",
            "cr_label_color"
          ]
        },
        "submit_button": {
          "title": "Button"
        },
        "suc_err_msg": {
          "title": "Message",
          "settings": [
            "cf7_message_padding",
            "cf7_message_margin_top",
            "cf7_message_alignment",
            "cf7_message_color",
            "cf7_message_bg_color",
            "cf7_border_highlight_color",
            "cf7_success_message_color",
            "cf7_success_message_bg_color",
            "cf7_success_border_color",
            "cf7_error_message_color",
            "cf7_error_message_bg_color",
            "cf7_error_border_color"
          ]
        }
      }
    }
  },
  "attributes": {
    "elementAttributes": {
      "content": {
        "optionAttributes": {
          "cf7": {
            "type": "select",
            "label": "Select Form",
            "description": "Choose a contact form to display.",
            "default": "0"
          },
          "use_form_header": {
            "type": "boolean",
            "label": "Show Form Header",
            "default": false
          },
          "form_header_title": {
            "type": "text",
            "label": "Header Title",
            "show_if": {
              "use_form_header": true
            }
          },
          "form_header_text": {
            "type": "text",
            "label": "Header Text",
            "show_if": {
              "use_form_header": true
            }
          },
          "use_icon": {
            "type": "boolean",
            "label": "Use Icon",
            "default": false,
            "show_if": {
              "use_form_header": true
            }
          },
          "header_icon": {
            "type": "icon",
            "label": "Header Icon",
            "show_if": {
              "use_form_header": true,
              "use_icon": true
            }
          },
          "header_img": {
            "type": "upload",
            "label": "Header Image",
            "show_if": {
              "use_form_header": true,
              "use_icon": false
            }
          },
          "use_form_button_fullwidth": {
            "type": "boolean",
            "label": "Fullwidth Button",
            "default": false
          },
          "button_alignment": {
            "type": "select",
            "label": "Button Alignment",
            "options": [
              { "value": "left", "label": "Left" },
              { "value": "center", "label": "Center" },
              { "value": "right", "label": "Right" }
            ],
            "default": "left",
            "show_if": {
              "use_form_button_fullwidth": false
            }
          }
        }
      },
      "advanced": {
        "optionAttributes": {
          "form_header": {
            "form_header_bg": {
              "type": "color",
              "label": "Form Header Background"
            },
            "form_header_bottom": {
              "type": "range",
              "label": "Bottom Spacing",
              "default": "0px",
              "range": {
                "min": 0,
                "max": 100,
                "step": 1
              }
            },
            "form_header_img_bg": {
              "type": "color",
              "label": "Header Image/Icon Background"
            },
            "form_header_icon_color": {
              "type": "color",
              "label": "Header Icon Color",
              "show_if": {
                "use_icon": true
              }
            }
          },
          "common": {
            "form_bg": {
              "type": "color",
              "label": "Form Background"
            },
            "form_padding": {
              "type": "padding",
              "label": "Form Padding",
              "default": "0px|0px|0px|0px"
            }
          },
          "form_field": {
            "form_field_height": {
              "type": "range",
              "label": "Common Text Fields Height",
              "description": "Here you can define static height for the common text fields.",
              "default": "0px",
              "range": {
                "min": 0,
                "max": 100,
                "step": 1
              }
            },
            "form_field_padding": {
              "type": "padding",
              "label": "Form Field Padding",
              "description": "Here you can define a custom padding for each field.",
              "default": "10px|15px|10px|15px"
            },
            "form_background_color": {
              "type": "color",
              "label": "Form Field Background Color",
              "default": "#f5f5f5"
            },
            "form_field_active_color": {
              "type": "color",
              "label": "Form Field Active Color"
            },
            "form_field_spacing": {
              "type": "range",
              "label": "Form Field Spacing Bottom",
              "description": "Set how much space the form field will take at the bottom.",
              "default": "20px",
              "range": {
                "min": 0,
                "max": 200,
                "step": 1
              }
            }
          },
          "radio_checkbox": {
            "cr_custom_styles": {
              "type": "boolean",
              "label": "Enable Custom Styles",
              "default": false
            },
            "cr_size": {
              "type": "range",
              "label": "Size",
              "default": "20px",
              "range": {
                "min": 0,
                "max": 50,
                "step": 1
              },
              "show_if": {
                "cr_custom_styles": true
              }
            },
            "cr_background_color": {
              "type": "color",
              "label": "Background Color",
              "show_if": {
                "cr_custom_styles": true
              }
            },
            "cr_selected_color": {
              "type": "color",
              "label": "Selected Color",
              "default": "#222222",
              "show_if": {
                "cr_custom_styles": true
              }
            },
            "cr_border_color": {
              "type": "color",
              "label": "Border Color",
              "default": "#222222",
              "show_if": {
                "cr_custom_styles": true
              }
            },
            "cr_border_size": {
              "type": "range",
              "label": "Border Size",
              "default": "1px",
              "range": {
                "min": 0,
                "max": 5,
                "step": 1
              },
              "show_if": {
                "cr_custom_styles": true
              }
            },
            "cr_label_color": {
              "type": "color",
              "label": "Label Color",
              "show_if": {
                "cr_custom_styles": true
              }
            }
          },
          "suc_err_msg": {
            "cf7_message_padding": {
              "type": "range",
              "label": "Message Padding",
              "default": "0px",
              "range": {
                "min": 0,
                "max": 50,
                "step": 1
              }
            },
            "cf7_message_margin_top": {
              "type": "range",
              "label": "Message Margin Top",
              "default": "0px",
              "range": {
                "min": 0,
                "max": 50,
                "step": 1
              }
            },
            "cf7_message_alignment": {
              "type": "select",
              "label": "Message Text Alignment",
              "description": "Align message text to the left, right or center.",
              "options": [
                { "value": "left", "label": "Left" },
                { "value": "center", "label": "Center" },
                { "value": "right", "label": "Right" }
              ],
              "default": "left"
            },
            "cf7_message_color": {
              "type": "color",
              "label": "Message Text Color"
            },
            "cf7_message_bg_color": {
              "type": "color",
              "label": "Message Background Color"
            },
            "cf7_border_highlight_color": {
              "type": "color",
              "label": "Border Highlight Color"
            },
            "cf7_success_message_color": {
              "type": "color",
              "label": "Success Message Text Color"
            },
            "cf7_success_message_bg_color": {
              "type": "color",
              "label": "Success Message Background Color"
            },
            "cf7_success_border_color": {
              "type": "color",
              "label": "Success Border Color"
            },
            "cf7_error_message_color": {
              "type": "color",
              "label": "Error Message Text Color"
            },
            "cf7_error_message_bg_color": {
              "type": "color",
              "label": "Error Message Background Color"
            },
            "cf7_error_border_color": {
              "type": "color",
              "label": "Error Border Color"
            }
          }
        }
      }
    }
  }
}
