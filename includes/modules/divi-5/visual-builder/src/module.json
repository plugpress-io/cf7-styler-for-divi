        "form_text": {
          "title": "Form Text",
          "tabbedSubtoggles": true,
          "subToggles": {
            "field_tab": {
              "name": "Field"
            },
            "label_tab": {
              "name": "Label"
            },
            "placeholder_tab": {
              "name": "Placeholder"
            }
          }
        }
      }
    }
  },
  "attributes": {
